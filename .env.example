SITE_DOMAIN=example.com

# RisuAI save data mount (host path or named volume)
# RISUAI_SAVE_DIR=/path/to/save
# RISUAI_SAVE_DIR=risuai-save  (default: named volume)

# SQLite data mount (host path or named volume)
# SQLITE_DATA_DIR=/path/to/sqlite
# SQLITE_DATA_DIR=sqlite-data  (default: named volume)

# Caddy host port mapping
# CADDY_HTTPS_PORT=6001  (default)
# CADDY_HTTP_PORT=6002   (default)

# Cloudflare Tunnel (--profile tunnel)
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# Build context paths (relative to this directory)
# RISUAI_DIR=../../../
# SQLITE_DIR=../with-sqlite
# SYNC_DIR=../sync
